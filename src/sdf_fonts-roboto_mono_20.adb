   function Get_Atlas_Pixel (X, Y : Atlas_Coordinate) return Distance is
      J : constant Integer := Integer (141.5 - Y);
      K : constant Integer := Natural (X + 0.5);
   begin
      return
       (if J in Map'Range (1) and K in Map'Range (2)
        then (Map (J, K) - 127) * Distance'Small else 0.0);
   end Get_Atlas_Pixel;

   procedure Render_Glyph
     (X     : in out Pixel_Coordinate;
      Y     : Pixel_Coordinate;
      Scale : Font_Scale;
      Index : Glyph_Index)
   is
      procedure Internal is new SDF_Fonts.Render_Glyph
        (Pixel_Coordinate, Draw_Pixel, Get_Glyph, Distance, Get_Atlas_Pixel);
   begin
      Internal (X, Y, Scale, Index);
   end Render_Glyph;


